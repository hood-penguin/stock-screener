# Database
DATABASE_URL=postgresql+asyncpg://postgres:localpassword@db:5432/stockscreener
DATABASE_ECHO=False

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=your-super-secret-key-change-this-to-a-random-32-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Market Data APIs
POLYGON_API_KEY=pk_xxxxx  # Set in production
DART_API_KEY=your_dart_api_key

# Application
DEBUG=True
ENVIRONMENT=development
API_TITLE=Stock Screener API
API_VERSION=1.0.0

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/v1

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Logging
LOG_LEVEL=INFO
